# Beauty Affiliate Agent — Environment Variables
# Copy this to .env and fill in your keys

# ── ANTHROPIC ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── PRODUCT DISCOVERY ─────────────────────────
# Sign up free at serpapi.com (100 searches/month free)
SERPAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AFFILIATE IDs ─────────────────────────────

# Amazon Associates
# Go to: affiliate-program.amazon.com → your tracking ID (format: yourbrand-20)
AMAZON_AFFILIATE_ID=yourbrand-20

# Sephora via Rakuten Advertising
# Go to: rakutenadvertising.com → apply for Sephora program → get your publisher ID
SEPHORA_AFFILIATE_ID=your_rakuten_publisher_id

# eBay Partner Network
# Go to: partnernetwork.ebay.com → create campaign → get Campaign ID
EBAY_CAMPAIGN_ID=your_ebay_campaign_id

# Ulta via Impact
# Go to: impact.com → search Ulta → apply → get your media ID
ULTA_AFFILIATE_ID=your_impact_media_id

# Glossier via ShareASale
# Go to: shareasale.com → search Glossier → apply → affiliate ID shown in dashboard
GLOSSIER_AFFILIATE_ID=your_shareasale_id

# ── INSTAGRAM POSTING ─────────────────────────

# Buffer API
# Go to: buffer.com → Settings → API → Create Token
BUFFER_TOKEN=your_buffer_access_token

# Your Instagram profile ID in Buffer
# Go to: buffer.com → API → GET /profiles → find your Instagram profile id
BUFFER_PROFILE_ID=your_instagram_profile_id

# ── VIDEO CREATION (optional, for Kling AI integration) ──
# Go to: klingai.com → API access (waitlist)
KLING_API_KEY=your_kling_api_key

# RunwayML (alternative to Kling)
# Go to: runwayml.com → API → generate key
RUNWAY_API_KEY=your_runway_api_key
